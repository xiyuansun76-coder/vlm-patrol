# ═══════════════════════════════════════════════
# VLM-Patrol + SmartAgri Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# ── SmartAgri Web Platform ──
SMARTAGRI_PORT=8000
SMARTAGRI_USER=admin
SMARTAGRI_PASS=admin
SMARTAGRI_API_TOKEN=change-me-token
SMARTAGRI_SESSION_SECRET=change-me-session-secret
SMARTAGRI_DB_PATH=smartagri.db

# ── MQTT Broker ──
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883

# ── Hikvision Camera ──
HIK_CAM_URL=http://192.168.1.100
HIK_CAM_USER=admin
HIK_CAM_PASS=

# ── go2rtc (WebRTC streaming) ──
GO2RTC_URL=http://127.0.0.1:1984

# ── LLM / VLM ──
OLLAMA_URL=http://localhost:11434/api/chat
VLM_MODEL=qwen3-vl:8b
LLM_API_KEY=
NVIDIA_API_KEY=

# ── VLM-Patrol Service ──
VLP_SERVICE_URL=http://127.0.0.1:8765

# ── PTZ Camera (for VLM-Patrol) ──
PTZ_USER=admin
PTZ_PASS=

# ── Patrol History ──
PATROL_HISTORY_DIR=patrol_history

# ── Optional: Supabase Cloud Sync ──
SUPABASE_URL=
SUPABASE_KEY=

# ── Intent Detection (setup assistant) ──
LOCAL_INTENT_MODEL=qwen3:0.6b
INTENT_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
INTENT_LLM_MODEL=meta/llama-3.1-8b-instruct
INTENT_LLM_KEY=

# ── Security ──
# VLP_SECRET=your-encryption-passphrase
# INTENT_RATE_LIMIT=20
# INTENT_CACHE_SIZE=128
# INTENT_CACHE_TTL=300
