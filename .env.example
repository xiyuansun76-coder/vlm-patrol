# LLM API key (for cloud providers like NVIDIA, OpenAI, etc.)
# Leave empty if using local Ollama
# Supports encrypted keys: run `python -c "from vlm_patrol.setup_assistant import encrypt_api_key; print(encrypt_api_key('your-key'))"`
LLM_API_KEY=

# Optional: Encryption passphrase for API keys (default: vlm-patrol-default-key)
# VLP_SECRET=your-secret-passphrase

# Optional: Intent detection LLM for setup assistant
# Priority: local Ollama → cloud API → keyword fallback
# Local Ollama (auto-detected, no config needed if running on localhost:11434)
LOCAL_INTENT_MODEL=qwen3:0.6b
# Cloud fallback (NVIDIA free tier)
INTENT_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
INTENT_LLM_MODEL=meta/llama-3.1-8b-instruct
INTENT_LLM_KEY=

# Rate limiting: max intent LLM calls per minute (default: 20)
# INTENT_RATE_LIMIT=20

# Intent cache: size and TTL in seconds (default: 128 entries, 5 min)
# INTENT_CACHE_SIZE=128
# INTENT_CACHE_TTL=300

# Optional: PTZ camera credentials
PTZ_USER=admin
PTZ_PASS=
